# AI API 配置文件
# 复制此文件为 .env 并填入你的 API Key
# 注意：本开源版后端库本身不读取 .env 文件，此文件供使用方参考。
# 在原完整项目中，ai_service_factory.dart 会通过 flutter_dotenv 读取默认 Key。

# OpenAI API Key
# 注册地址: https://platform.openai.com/
# 按量付费
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API Key
# 注册地址: https://platform.deepseek.com/
# 免费额度: 无限制
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 硅基流动 API Key
# 注册地址: https://guiji.ai/
# 免费额度: 无限制免费
GUIJI_API_KEY=your_guiji_api_key_here

# 智谱AI API Key (GLM-4)
# 注册地址: https://open.bigmodel.cn/
# 免费额度: 新用户赠送
ZHIPU_API_KEY=your_zhipu_api_key_here

# 月之暗面 Kimi API Key
# 注册地址: https://platform.moonshot.cn/
# 免费额度: 新用户赠送
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 豆包 API Key（火山引擎）
# 注册地址: https://console.volcengine.com/ark
# 免费额度: 200万 token
DOUBAO_API_KEY=your_doubao_api_key_here

# 通义千问 API Key（阿里云）
# 注册地址: https://bailian.console.aliyun.com/
# 免费额度: 每月 500万 token
TONGYI_API_KEY=your_tongyi_api_key_here

# 混元 API Key（腾讯云）
# 注册地址: https://cloud.tencent.com/product/hunyuan
# 免费额度: 每日 10万 token
HUNYUAN_API_KEY=your_hunyuan_api_key_here

# MiniMax API Key
# 注册地址: https://platform.minimaxi.com/
# 免费额度: 新用户赠送
MINIMAX_API_KEY=your_minimax_api_key_here

# 阶跃星辰 API Key
# 注册地址: https://platform.stepfun.com/
# 免费额度: 新用户赠送
STEPFUN_API_KEY=your_stepfun_api_key_here

# 百川智能 API Key
# 注册地址: https://platform.baichuan-ai.com/
# 免费额度: 新用户赠送
BAICHUAN_API_KEY=your_baichuan_api_key_here

# 讯飞星火 API Key
# 注册地址: https://xinghuo.xfyun.cn/
# 免费额度: 200万 token
SPARK_API_KEY=your_spark_api_key_here

# 零一万物 API Key
# 注册地址: https://platform.lingyiwanwu.com/
# 免费额度: 新用户赠送
YI_API_KEY=your_yi_api_key_here

# 文心一言 API Key（百度千帆）
# 注册地址: https://console.bce.baidu.com/qianfan/
# 免费额度: 新用户赠送
ERNIE_API_KEY=your_ernie_api_key_here

# Gemini API Key（Google）
# 注册地址: https://ai.google.dev/
# 免费额度: 每月 60万 token
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Key
# 注册地址: https://huggingface.co/
# 免费额度: 每月 100万 token
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
